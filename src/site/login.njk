    <style>
    /* Dark Theme & Glowing Lavender */
    :root {
        --bg-color: #0b0710;
        --card-bg: rgba(25, 15, 35, 0.45);
        --card-border: rgba(196, 158, 255, 0.15);
        --text-main: #e8e3f5;
        --text-accent: #c49eff;
        --input-bg: rgba(255, 255, 255, 0.03);
        --input-border: rgba(196, 158, 255, 0.2);
        --input-focus: #d4b3ff;
        --btn-bg: linear-gradient(135deg, #8a4fff, #c49eff);
        --btn-hover-shadow: rgba(196, 158, 255, 0.5);
        --font-main: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
    }

    * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
    }

    body {
        margin: 0;
        padding: 0;
        min-height: 100vh;
        display: flex;
        justify-content: center;
        align-items: center;
        background-color: var(--bg-color);
        font-family: var(--font-main);
        color: var(--text-main);
        overflow-x: hidden;
        position: relative;
    }

    /* Animated ambient glowing orbs */
    body::before, body::after {
        content: '';
        position: absolute;
        border-radius: 50%;
        filter: blur(100px);
        z-index: 0;
        animation: float 12s ease-in-out infinite alternate;
        pointer-events: none;
    }

    body::before {
        width: 400px;
        height: 400px;
        background: rgba(138, 79, 255, 0.18);
        top: 15%;
        left: 20%;
        animation-delay: 0s;
    }

    body::after {
        width: 500px;
        height: 500px;
        background: rgba(196, 158, 255, 0.12);
        bottom: 10%;
        right: 15%;
        animation-delay: -6s;
    }

    @keyframes float {
        0% { 
            transform: translate(0px, 0px) scale(1);
            opacity: 0.6;
        }
        50% {
            transform: translate(-40px, 50px) scale(1.1);
            opacity: 0.8;
        }
        100% { 
            transform: translate(30px, -40px) scale(0.95);
            opacity: 0.6;
        }
    }

    .login-card {
        background: var(--card-bg);
        padding: 3rem 2.5rem;
        border-radius: 24px;
        box-shadow: 0 20px 60px rgba(0, 0, 0, 0.6), 
                    inset 0 1px 0 rgba(255, 255, 255, 0.1);
        backdrop-filter: blur(25px) saturate(180%);
        -webkit-backdrop-filter: blur(25px) saturate(180%);
        border: 1px solid var(--card-border);
        width: 100%;
        max-width: 450px;
        text-align: center;
        position: relative;
        z-index: 1;
        animation: cardEntrance 0.8s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
    }

    @keyframes cardEntrance {
        from { 
            opacity: 0; 
            transform: translateY(30px) scale(0.95);
        }
        to { 
            opacity: 1; 
            transform: translateY(0) scale(1);
        }
    }

    h1 {
        font-family: 'Georgia', serif;
        color: var(--text-main);
        margin-bottom: 0.5rem;
        font-size: 2.5rem;
        font-weight: 700;
        letter-spacing: 2px;
        background: linear-gradient(135deg, var(--text-accent), var(--text-main));
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        text-shadow: 0 0 30px rgba(196, 158, 255, 0.4);
        animation: glow 3s ease-in-out infinite alternate;
    }

    @keyframes glow {
        from { filter: drop-shadow(0 0 10px rgba(196, 158, 255, 0.3)); }
        to { filter: drop-shadow(0 0 20px rgba(196, 158, 255, 0.5)); }
    }

    p.subtitle {
        font-size: 1rem;
        color: #a097b5;
        margin-bottom: 2.5rem;
        font-style: italic;
        letter-spacing: 0.5px;
        opacity: 0;
        animation: fadeInUp 0.8s ease-out 0.3s forwards;
    }

    @keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(10px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .input-group {
        margin-bottom: 1.5rem;
        text-align: left;
        opacity: 0;
        animation: fadeInUp 0.8s ease-out 0.5s forwards;
    }

    .input-group label {
        display: block;
        font-size: 0.9rem;
        margin-bottom: 0.6rem;
        color: var(--text-accent);
        font-weight: 500;
        letter-spacing: 0.5px;
    }

    .input-group input {
        width: 100%;
        padding: 1rem;
        background: var(--input-bg);
        border: 1px solid var(--input-border);
        border-radius: 12px;
        box-sizing: border-box;
        font-size: 1rem;
        color: #ffffff;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        font-family: inherit;
    }

    .input-group input::placeholder {
        color: rgba(232, 227, 245, 0.3);
    }

    .input-group input:focus {
        outline: none;
        border-color: var(--input-focus);
        background: rgba(255, 255, 255, 0.08);
        box-shadow: 0 0 0 3px rgba(212, 179, 255, 0.2),
                    0 0 20px rgba(212, 179, 255, 0.3);
        transform: translateY(-2px);
    }

    button[type="submit"] {
        width: 100%;
        padding: 1rem;
        background: var(--btn-bg);
        color: white;
        border: none;
        border-radius: 12px;
        font-size: 1.05rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1.2px;
        cursor: pointer;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        margin-top: 0.5rem;
        box-shadow: 0 6px 20px rgba(138, 79, 255, 0.3);
        position: relative;
        overflow: hidden;
        opacity: 0;
        animation: fadeInUp 0.8s ease-out 0.7s forwards;
    }

    button[type="submit"]::before {
        content: '';
        position: absolute;
        top: 50%;
        left: 50%;
        width: 0;
        height: 0;
        border-radius: 50%;
        background: rgba(255, 255, 255, 0.2);
        transform: translate(-50%, -50%);
        transition: width 0.6s, height 0.6s;
    }

    button[type="submit"]:hover {
        box-shadow: 0 10px 30px var(--btn-hover-shadow);
        transform: translateY(-3px);
    }

    button[type="submit"]:hover::before {
        width: 400px;
        height: 400px;
    }
    
    button[type="submit"]:active {
        transform: translateY(-1px) scale(0.98);
        box-shadow: 0 4px 15px rgba(138, 79, 255, 0.4);
    }

    .toggle-link {
        margin-top: 2rem;
        font-size: 0.9rem;
        color: #a097b5;
        cursor: pointer;
        text-decoration: none;
        display: inline-block;
        transition: all 0.3s ease;
        border-bottom: 1px solid transparent;
        position: relative;
        opacity: 0;
        animation: fadeInUp 0.8s ease-out 0.9s forwards;
    }

    .toggle-link::after {
        content: '';
        position: absolute;
        width: 0;
        height: 2px;
        bottom: -2px;
        left: 50%;
        background: linear-gradient(90deg, var(--text-accent), transparent);
        transition: all 0.3s ease;
        transform: translateX(-50%);
    }

    .toggle-link:hover {
        color: var(--text-accent);
    }

    .toggle-link:hover::after {
        width: 100%;
    }

    .hidden {
        display: none;
    }
    
    #error-msg {
        color: #ff6b6b;
        font-size: 0.9rem;
        margin-bottom: 1rem;
        min-height: 20px;
        font-weight: 500;
        text-shadow: 0 0 10px rgba(255, 107, 107, 0.4);
        padding: 0.5rem;
        border-radius: 8px;
        background: rgba(255, 107, 107, 0.1);
        border: 1px solid rgba(255, 107, 107, 0.3);
        animation: shake 0.5s ease-in-out;
    }

    #error-msg:empty {
        padding: 0;
        border: none;
        background: none;
    }

    @keyframes shake {
        0%, 100% { transform: translateX(0); }
        25% { transform: translateX(-10px); }
        75% { transform: translateX(10px); }
    }

    /* Responsive design */
    @media (max-width: 600px) {
        .login-card {
            padding: 2rem 1.5rem;
            margin: 1rem;
        }

        h1 {
            font-size: 2rem;
        }

        body::before,
        body::after {
            filter: blur(60px);
        }
    }

    /* Loading state for button */
    button[type="submit"]:disabled {
        opacity: 0.7;
        cursor: not-allowed;
        animation: pulse 1.5s ease-in-out infinite;
    }

    @keyframes pulse {
        0%, 100% { opacity: 0.7; }
        50% { opacity: 0.5; }
    }
</style>
</head>
<body>

    <div class="login-card">
        <h1>Kartik & Vaibhav</h1>
        <p class="subtitle">Our little corner of the internet.</p>
        
        <div id="error-msg"></div>

        <!-- Standard Password Form -->
        <form id="password-form" onsubmit="handleLogin(event, 'password')">
            <div class="input-group">
                <label for="password">Our Secret Password</label>
                <input type="password" id="password" name="password" required placeholder="Enter password...">
            </div>
            <button type="submit">Unlock</button>
        </form>

        <!-- Alternative Q&A Form -->
        <form id="questions-form" class="hidden" onsubmit="handleLogin(event, 'questions')">
            <div class="input-group">
                <label for="q1">1. Name of Vaibhu's boobies?</label>
                <input type="text" id="q1" name="q1" required placeholder="Your answer...">
            </div>
            <div class="input-group">
                <label for="q2">2. Our anniversary date is? (format: DD/MM/YYYY)</label>
                <input type="text" id="q2" name="q2" required placeholder="Your answer...">
            </div>
            <div class="input-group">
                <label for="q3">3. Our fav emojis are? (in correct order, without space)</label>
                <input type="text" id="q3" name="q3" required placeholder="Your answer...">
            </div>
            <button type="submit">Unlock</button>
        </form>

        <div class="toggle-link" onclick="toggleForms()">Or answer our personal questions</div>
    </div>

    <script>
        // Toggles between the password and the 3 questions
        function toggleForms() {
            const pwdForm = document.getElementById('password-form');
            const qForm = document.getElementById('questions-form');
            const toggleLink = document.querySelector('.toggle-link');
            const errorMsg = document.getElementById('error-msg');
            
            errorMsg.innerText = ''; // Clear errors on toggle

            if (pwdForm.classList.contains('hidden')) {
                pwdForm.classList.remove('hidden');
                qForm.classList.add('hidden');
                toggleLink.innerText = 'Or answer our personal questions';
            } else {
                pwdForm.classList.add('hidden');
                qForm.classList.remove('hidden');
                toggleLink.innerText = 'Use our secret password instead';
            }
        }

        // Submits the data to our Vercel Serverless Function (which we will build next)
        async function handleLogin(e, type) {
            e.preventDefault();
            const errorMsg = document.getElementById('error-msg');
            const btn = e.target.querySelector('button');
            errorMsg.innerText = '';
            
            // Temporary loading state
            const originalBtnText = btn.innerText;
            btn.innerText = 'CHECKING...';

            const formData = new FormData(e.target);
            const data = Object.fromEntries(formData.entries());
            data.loginType = type; // Tells the backend which method we used

            try {
                const response = await fetch('/api/login', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data)
                });

                if (response.ok) {
                    window.location.href = '/'; // Success! Redirect to the garden
                } else {
                    const resData = await response.json();
                    errorMsg.innerText = resData.message || 'Incorrect. Try again, love. ❤️';
                    btn.innerText = originalBtnText;
                }
            } catch (err) {
                errorMsg.innerText = 'Network error. Please try again.';
                btn.innerText = originalBtnText;
            }
        }
    </script>
</body>
</html>