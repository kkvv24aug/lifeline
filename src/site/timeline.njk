<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Our Journey</title>
    <!-- Assuming your custom-style.css is linked in your main layout, otherwise link it here -->
    <link href="/styles/custom-style.css" rel="stylesheet">
    <style>
        /* Specific Timeline Layout Styles */
        .timeline-container {
            max-width: 800px;
            margin: 100px auto;
            padding: 20px;
        }

        .upcoming-section {
            background: var(--card-bg);
            border: 1px solid var(--card-border);
            border-radius: 20px;
            padding: 30px;
            margin-bottom: 50px;
            backdrop-filter: blur(20px);
            box-shadow: 0 10px 30px rgba(0,0,0,0.3);
            text-align: center;
        }

        .upcoming-title {
            color: var(--text-accent);
            font-size: 1.5rem;
            margin-bottom: 20px;
            font-family: 'Georgia', serif;
        }

        .nearest-event {
            font-size: 2rem;
            font-weight: bold;
            color: #fff;
            text-shadow: 0 0 10px rgba(196, 158, 255, 0.4);
        }

        .event-meta {
            color: var(--text-muted);
            font-size: 1.1rem;
            margin-top: 10px;
        }

        /* The Vertical Journey Timeline */
        .journey-list {
            position: relative;
            padding-left: 30px;
            border-left: 2px solid var(--text-accent);
        }

        .entry-card {
            position: relative;
            background: rgba(255, 255, 255, 0.03);
            border: 1px solid rgba(196, 158, 255, 0.1);
            border-radius: 12px;
            padding: 20px;
            margin-bottom: 25px;
            transition: transform 0.3s ease;
        }

        .entry-card:hover {
            transform: translateX(5px);
            background: rgba(255, 255, 255, 0.05);
            border-color: var(--text-accent);
        }

        /* The dot on the timeline */
        .entry-card::before {
            content: '';
            position: absolute;
            left: -37px;
            top: 25px;
            width: 12px;
            height: 12px;
            border-radius: 50%;
            background: var(--text-accent);
            box-shadow: 0 0 10px var(--text-accent);
        }

        .entry-date {
            font-size: 0.85rem;
            color: var(--text-accent);
            font-weight: 600;
            margin-bottom: 5px;
        }

        .entry-time {
            font-size: 0.8rem;
            color: var(--text-muted);
            margin-left: 10px;
        }

        .entry-message {
            color: var(--text-main);
            line-height: 1.5;
            font-size: 1.05rem;
        }

        /* Distinct UI for Recurring Events in the general timeline */
        .type-recurring {
            border-left: 4px solid var(--interactive-accent);
        }
        
        .type-recurring::before {
            background: var(--interactive-accent);
            box-shadow: 0 0 10px var(--interactive-accent);
        }
    </style>
</head>
<body>

    <div class="timeline-container">
        
        <!-- Upcoming Celebrations Highlight -->
        <div class="upcoming-section">
            <div class="upcoming-title">✨ Next Up</div>
            <div id="upcoming-event-container">
                <p>Loading our next celebration...</p>
            </div>
        </div>

        <!-- The Chronological Journey -->
        <h2 style="color: var(--text-main); font-family: 'Georgia', serif; text-align: center; margin-bottom: 30px;">Our Journey</h2>
        <div class="journey-list" id="journey-container">
            <!-- Entries injected here via JS -->
        </div>

    </div>

    <!-- Timeline Logic -->
    <script>
        document.addEventListener('DOMContentLoaded', async () => {
            try {
                // Fetch the static JSON data generated by 11ty
                // If you placed the json in _data, 11ty can serve it as an endpoint. 
                // Alternatively, you can inject it directly into a global variable.
                const response = await fetch('/api/timeline-data.json'); // We will create this endpoint below
                const entries = await response.json();

                renderUpcoming(entries);
                renderTimeline(entries);
            } catch (error) {
                console.error("Failed to load timeline data", error);
            }
        });

        function renderUpcoming(entries) {
            const recurringEvents = entries.filter(e => e.type === 'recurring');
            const today = new Date();
            let nearestEvent = null;
            let smallestDiff = Infinity;
            let calculatedYears = 0;

            recurringEvents.forEach(event => {
                const originalDate = new Date(event.date);
                
                // Construct this year's occurrence
                let nextOccurrence = new Date(today.getFullYear(), originalDate.getMonth(), originalDate.getDate());
                
                // If it already passed this year, look at next year
                if (nextOccurrence < today) {
                    nextOccurrence.setFullYear(today.getFullYear() + 1);
                }

                const diffTime = nextOccurrence - today;
                const diffDays = Math.ceil(diffTime / (1000 * 60 * 60 * 24));

                if (diffDays < smallestDiff) {
                    smallestDiff = diffDays;
                    nearestEvent = event;
                    calculatedYears = nextOccurrence.getFullYear() - originalDate.getFullYear();
                }
            });

            const container = document.getElementById('upcoming-event-container');
            if (nearestEvent) {
                // Formatting date nicely
                const options = { month: 'long', day: 'numeric' };
                const dateStr = new Date(nearestEvent.date).toLocaleDateString('en-US', options);
                
                // Logic for "st", "nd", "rd", "th"
                const suffix = ["th", "st", "nd", "rd"][((calculatedYears % 100) >= 11 && (calculatedYears % 100) <= 13) ? 0 : (calculatedYears % 10) < 4 ? (calculatedYears % 10) : 0];

                container.innerHTML = `
                    <div class="nearest-event">${nearestEvent.message}</div>
                    <div class="event-meta">
                        Coming up on <strong>${dateStr}</strong> (in ${smallestDiff} days) <br>
                        Celebrating the <strong>${calculatedYears}${suffix}</strong> year!
                    </div>
                `;
            } else {
                container.innerHTML = `<p>No recurring events found yet.</p>`;
            }
        }

        function renderTimeline(entries) {
            // Sort all entries strictly by date (oldest first)
            const sortedEntries = entries.sort((a, b) => new Date(a.date) - new Date(b.date));
            const container = document.getElementById('journey-container');
            container.innerHTML = '';

            sortedEntries.forEach(entry => {
                const options = { year: 'numeric', month: 'short', day: 'numeric' };
                const formattedDate = new Date(entry.date).toLocaleDateString('en-US', options);
                const timeStr = entry.time ? `<span class="entry-time">@ ${entry.time}</span>` : '';
                
                const card = document.createElement('div');
                card.className = `entry-card type-${entry.type}`; // Applies distinct UI based on type
                card.innerHTML = `
                    <div class="entry-date">${formattedDate} ${timeStr}</div>
                    <div class="entry-message">${entry.message}</div>
                `;
                container.appendChild(card);
            });
        }
    </script>
</body>
</html>