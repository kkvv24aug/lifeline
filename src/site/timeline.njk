<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Our Journey</title>
    <!-- Assuming your custom-style.css is linked in your main layout, otherwise link it here -->
    <link href="/styles/custom-style.css" rel="stylesheet">
    <style>
        /* Specific Timeline Layout Styles */
        .timeline-container {
            max-width: 800px;
            margin: 100px auto;
            padding: 20px;
        }

        .upcoming-section {
            background: var(--card-bg);
            border: 1px solid var(--card-border);
            border-radius: 20px;
            padding: 30px;
            margin-bottom: 50px;
            backdrop-filter: blur(20px);
            box-shadow: 0 10px 30px rgba(0,0,0,0.3);
            text-align: center;
        }

        .upcoming-title {
            color: var(--text-accent);
            font-size: 1.5rem;
            margin-bottom: 20px;
            font-family: 'Georgia', serif;
        }

        .nearest-event {
            font-size: 2rem;
            font-weight: bold;
            color: #fff;
            text-shadow: 0 0 10px rgba(196, 158, 255, 0.4);
        }

        .event-meta {
            color: var(--text-muted);
            font-size: 1.1rem;
            margin-top: 10px;
        }

        /* The Vertical Journey Timeline */
        .journey-list {
            position: relative;
            padding-left: 30px;
            border-left: 2px solid var(--text-accent);
        }

        .entry-card {
            position: relative;
            background: rgba(255, 255, 255, 0.03);
            border: 1px solid rgba(196, 158, 255, 0.1);
            border-radius: 12px;
            padding: 20px;
            margin-bottom: 25px;
            transition: transform 0.3s ease;
        }

        .entry-card:hover {
            transform: translateX(5px);
            background: rgba(255, 255, 255, 0.05);
            border-color: var(--text-accent);
        }

        /* The dot on the timeline */
        .entry-card::before {
            content: '';
            position: absolute;
            left: -37px;
            top: 25px;
            width: 12px;
            height: 12px;
            border-radius: 50%;
            background: var(--text-accent);
            box-shadow: 0 0 10px var(--text-accent);
        }

        .entry-date {
            font-size: 0.85rem;
            color: var(--text-accent);
            font-weight: 600;
            margin-bottom: 5px;
        }

        .entry-time {
            font-size: 0.8rem;
            color: var(--text-muted);
            margin-left: 10px;
        }

        .entry-message {
            color: var(--text-main);
            line-height: 1.5;
            font-size: 1.05rem;
        }

        /* Distinct UI for Recurring Events in the general timeline */
        .type-recurring {
            border-left: 4px solid var(--interactive-accent);
        }
        
        .type-recurring::before {
            background: var(--interactive-accent);
            box-shadow: 0 0 10px var(--interactive-accent);
        }

        /* =========================================
ADD THIS INSIDE <style>
========================================= */

/* Filter Buttons */
.timeline-filters {
    display: flex;
    justify-content: center;
    gap: 12px;
    margin-bottom: 30px;
    flex-wrap: wrap;
}

.filter-btn {
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(196,158,255,0.15);
    color: var(--text-main);
    padding: 10px 18px;
    border-radius: 999px;
    cursor: pointer;
    transition: all 0.3s ease;
    backdrop-filter: blur(10px);
}

.filter-btn:hover,
.filter-btn.active {
    background: var(--text-accent);
    color: #000;
    box-shadow: 0 0 15px rgba(196,158,255,0.35);
}

/* Scroll reveal animation */
.entry-card {
    opacity: 0;
    transform: translateY(40px);
    transition:
        opacity 0.7s ease,
        transform 0.7s ease,
        border-color 0.3s ease,
        background 0.3s ease;
}

.entry-card.visible {
    opacity: 1;
    transform: translateY(0);
}

/* Revolving border around Next Up */
.upcoming-section {
    position: relative;
    overflow: hidden;
}

.upcoming-section::before {
    content: '';
    position: absolute;
    inset: -2px;
    border-radius: inherit;
    padding: 2px;
    background: conic-gradient(
        from 0deg,
        transparent,
        var(--text-accent),
        var(--interactive-accent),
        transparent
    );
    animation: spinBorder 5s linear infinite;
    -webkit-mask:
        linear-gradient(#fff 0 0) content-box,
        linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
            mask-composite: exclude;
    pointer-events: none;
}

@keyframes spinBorder {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
}
    </style>
</head>
<body>

    <div class="timeline-container">
        
        <!-- Upcoming Celebrations Highlight -->
        <div class="upcoming-section">
            <div class="upcoming-title">Next Up</div>
            <div id="upcoming-event-container">
                <p>Loading our next celebration...</p>
            </div>
        </div>

        <!-- The Chronological Journey -->
        <h2 style="color: var(--text-main); font-family: 'Georgia', serif; text-align: center; margin-bottom: 30px;">Our Journey</h2>
        <div class="timeline-filters">
    <button class="filter-btn active" data-filter="all">All</button>
    <button class="filter-btn" data-filter="journal">Journal</button>
    <button class="filter-btn" data-filter="recurring">Recurring</button>
</div>
        <div class="journey-list" id="journey-container">
            <!-- Entries injected here via JS -->
        </div>

    </div>

    <!-- Timeline Logic -->
    <script>
        /* =========================================
REPLACE YOUR ENTIRE <script> WITH THIS
========================================= */
document.addEventListener('DOMContentLoaded', async () => {
    try {
        const response = await fetch('/api/timeline-data.json');
        const entries = await response.json();

        renderUpcoming(entries);
        renderTimeline(entries);
        setupFilters(entries);
    } catch (error) {
        console.error("Failed to load timeline data", error);
    }
});

function renderUpcoming(entries) {
    const recurringEvents = entries.filter(e => e.type === 'recurring');
    const today = new Date();
    let nearestEvent = null;
    let smallestDiff = Infinity;
    let calculatedYears = 0;

    recurringEvents.forEach(event => {
        const originalDate = new Date(event.date);
        let nextOccurrence = new Date(today.getFullYear(), originalDate.getMonth(), originalDate.getDate());

        if (nextOccurrence < today) {
            nextOccurrence.setFullYear(today.getFullYear() + 1);
        }

        const diffTime = nextOccurrence - today;
        const diffDays = Math.ceil(diffTime / (1000 * 60 * 60 * 24));

        if (diffDays < smallestDiff) {
            smallestDiff = diffDays;
            nearestEvent = event;
            calculatedYears = nextOccurrence.getFullYear() - originalDate.getFullYear();
        }
    });

    const container = document.getElementById('upcoming-event-container');

    if (nearestEvent) {
        const options = { month: 'long', day: 'numeric' };
        const dateStr = new Date(nearestEvent.date).toLocaleDateString('en-US', options);

        const suffix = ["th", "st", "nd", "rd"][
            ((calculatedYears % 100) >= 11 && (calculatedYears % 100) <= 13)
                ? 0
                : (calculatedYears % 10) < 4
                    ? (calculatedYears % 10)
                    : 0
        ];

        container.innerHTML = `
            <div class="nearest-event">${nearestEvent.message}</div>
            <div class="event-meta">
                Coming up on <strong>${dateStr}</strong> (in ${smallestDiff} days) <br>
                Celebrating the <strong>${calculatedYears}${suffix}</strong> year!
            </div>
        `;
    } else {
        container.innerHTML = `<p>No recurring events found yet.</p>`;
    }
}

function renderTimeline(entries, filter = "all") {
    const sortedEntries = [...entries].sort((a, b) => new Date(a.date) - new Date(b.date));
    const container = document.getElementById('journey-container');
    container.innerHTML = '';

    const filteredEntries = filter === "all"
        ? sortedEntries
        : sortedEntries.filter(entry => entry.type === filter);

    filteredEntries.forEach(entry => {
        const options = { year: 'numeric', month: 'short', day: 'numeric' };
        const formattedDate = new Date(entry.date).toLocaleDateString('en-US', options);
        const timeStr = entry.time ? `<span class="entry-time">@ ${entry.time}</span>` : '';

        const card = document.createElement('div');
        card.className = `entry-card type-${entry.type}`;
        card.innerHTML = `
            <div class="entry-date">${formattedDate} ${timeStr}</div>
            <div class="entry-message">${entry.message}</div>
        `;

        container.appendChild(card);
    });

    initializeScrollReveal();
}

function setupFilters(entries) {
    const buttons = document.querySelectorAll('.filter-btn');

    buttons.forEach(button => {
        button.addEventListener('click', () => {
            buttons.forEach(btn => btn.classList.remove('active'));
            button.classList.add('active');

            const filter = button.dataset.filter;
            renderTimeline(entries, filter);
        });
    });
}

function initializeScrollReveal() {
    const cards = document.querySelectorAll('.entry-card');

    const observer = new IntersectionObserver((entriesObs) => {
        entriesObs.forEach(entry => {
            if (entry.isIntersecting) {
                entry.target.classList.add('visible');
            }
        });
    }, {
        threshold: 0.12
    });

    cards.forEach(card => observer.observe(card));
}
    </script>
</body>
</html>