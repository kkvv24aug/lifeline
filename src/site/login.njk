<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Just For Us</title>
    <style>
        /* Lavender and Pink Theme */
        :root {
            --bg-gradient: linear-gradient(135deg, #e6e6fa, #fbc2eb);
            --card-bg: rgba(255, 255, 255, 0.65);
            --text-main: #4a4a4a;
            --text-accent: #b565a7; /* Deeper lavender/pink */
            --input-border: #d8bfd8;
            --input-focus: #fbc2eb;
            --btn-bg: #d8bfd8;
            --btn-hover: #c8a2c8;
            --font-main: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
        }

        body {
            margin: 0;
            padding: 0;
            height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            background: var(--bg-gradient);
            font-family: var(--font-main);
            color: var(--text-main);
        }

        .login-card {
            background: var(--card-bg);
            padding: 40px 30px;
            border-radius: 20px;
            box-shadow: 0 8px 32px rgba(181, 101, 167, 0.15);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border: 1px solid rgba(255, 255, 255, 0.4);
            width: 100%;
            max-width: 400px;
            text-align: center;
            transition: all 0.3s ease;
        }

        h1 {
            font-family: 'Georgia', serif;
            color: var(--text-accent);
            margin-bottom: 5px;
            font-size: 2rem;
            letter-spacing: 1px;
        }

        p.subtitle {
            font-size: 0.9rem;
            color: #777;
            margin-bottom: 30px;
            font-style: italic;
        }

        .input-group {
            margin-bottom: 20px;
            text-align: left;
        }

        .input-group label {
            display: block;
            font-size: 0.85rem;
            margin-bottom: 8px;
            color: var(--text-accent);
            font-weight: 600;
        }

        .input-group input {
            width: 100%;
            padding: 12px;
            border: 2px solid var(--input-border);
            border-radius: 10px;
            box-sizing: border-box;
            font-size: 1rem;
            transition: all 0.3s ease;
            background: rgba(255, 255, 255, 0.8);
            color: var(--text-main);
        }

        .input-group input:focus {
            outline: none;
            border-color: var(--input-focus);
            background: rgba(255, 255, 255, 1);
            box-shadow: 0 0 8px rgba(251, 194, 235, 0.5);
        }

        button[type="submit"] {
            width: 100%;
            padding: 14px;
            background: var(--btn-bg);
            color: white;
            border: none;
            border-radius: 10px;
            font-size: 1.1rem;
            font-weight: bold;
            cursor: pointer;
            transition: background 0.3s ease, transform 0.1s ease;
            margin-top: 10px;
            letter-spacing: 0.5px;
        }

        button[type="submit"]:hover {
            background: var(--btn-hover);
        }
        
        button[type="submit"]:active {
            transform: scale(0.98);
        }

        .toggle-link {
            margin-top: 25px;
            font-size: 0.85rem;
            color: var(--text-accent);
            cursor: pointer;
            text-decoration: underline;
            display: inline-block;
            transition: color 0.3s ease;
        }

        .toggle-link:hover {
            color: var(--btn-hover);
        }

        /* Hide elements smoothly */
        .hidden {
            display: none;
        }
        
        /* Error message styling */
        #error-msg {
            color: #d9534f;
            font-size: 0.9rem;
            margin-bottom: 15px;
            min-height: 20px;
            font-weight: 500;
        }
    </style>
</head>
<body>

    <div class="login-card">
        <h1>Kartik & Vaibhav</h1>
        <p class="subtitle">Our little corner of the internet.</p>
        
        <div id="error-msg"></div>

        <!-- Standard Password Form -->
        <form id="password-form" onsubmit="handleLogin(event, 'password')">
            <div class="input-group">
                <label for="password">Our Secret Password</label>
                <input type="password" id="password" name="password" required placeholder="Enter password...">
            </div>
            <button type="submit">Unlock</button>
        </form>

        <!-- Alternative Q&A Form -->
        <form id="questions-form" class="hidden" onsubmit="handleLogin(event, 'questions')">
            <div class="input-group">
                <label for="q1">1. Where did we first meet?</label>
                <input type="text" id="q1" name="q1" required placeholder="Your answer...">
            </div>
            <div class="input-group">
                <label for="q2">2. What is the name of our favorite movie?</label>
                <input type="text" id="q2" name="q2" required placeholder="Your answer...">
            </div>
            <div class="input-group">
                <label for="q3">3. What date did we make it official? (DD-MM-YYYY)</label>
                <input type="text" id="q3" name="q3" required placeholder="Your answer...">
            </div>
            <button type="submit">Unlock</button>
        </form>

        <div class="toggle-link" onclick="toggleForms()">Or answer our personal questions</div>
    </div>

    <script>
        // Toggles between the password and the 3 questions
        function toggleForms() {
            const pwdForm = document.getElementById('password-form');
            const qForm = document.getElementById('questions-form');
            const toggleLink = document.querySelector('.toggle-link');
            const errorMsg = document.getElementById('error-msg');
            
            errorMsg.innerText = ''; // Clear errors on toggle

            if (pwdForm.classList.contains('hidden')) {
                pwdForm.classList.remove('hidden');
                qForm.classList.add('hidden');
                toggleLink.innerText = 'Or answer our personal questions';
            } else {
                pwdForm.classList.add('hidden');
                qForm.classList.remove('hidden');
                toggleLink.innerText = 'Use our secret password instead';
            }
        }

        // Submits the data to our Vercel Serverless Function (which we will build next)
        async function handleLogin(e, type) {
            e.preventDefault();
            const errorMsg = document.getElementById('error-msg');
            const btn = e.target.querySelector('button');
            errorMsg.innerText = '';
            
            // Temporary loading state
            const originalBtnText = btn.innerText;
            btn.innerText = 'Checking...';

            const formData = new FormData(e.target);
            const data = Object.fromEntries(formData.entries());
            data.loginType = type; // Tells the backend which method we used

            try {
                const response = await fetch('/api/login', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data)
                });

                if (response.ok) {
                    window.location.href = '/'; // Success! Redirect to the garden
                } else {
                    const resData = await response.json();
                    errorMsg.innerText = resData.message || 'Incorrect. Try again, love. ❤️';
                    btn.innerText = originalBtnText;
                }
            } catch (err) {
                errorMsg.innerText = 'Network error. Please try again.';
                btn.innerText = originalBtnText;
            }
        }
    </script>
</body>
</html>