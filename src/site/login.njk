<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Just For Us</title>
    <style>
        /* Dark Theme & Glowing Lavender */
        :root {
            --bg-color: #0b0710;
            --card-bg: rgba(25, 15, 35, 0.45);
            --card-border: rgba(196, 158, 255, 0.15);
            --text-main: #e8e3f5;
            --text-accent: #c49eff; /* Pretty glowing lavender */
            --input-bg: rgba(255, 255, 255, 0.03);
            --input-border: rgba(196, 158, 255, 0.2);
            --input-focus: #d4b3ff;
            --btn-bg: linear-gradient(135deg, #8a4fff, #c49eff);
            --btn-hover-shadow: rgba(196, 158, 255, 0.4);
            --font-main: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
        }

        body {
            margin: 0;
            padding: 0;
            height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            background-color: var(--bg-color);
            font-family: var(--font-main);
            color: var(--text-main);
            overflow: hidden;
            position: relative;
        }

        /* Ambient glowing orbs to make the glassmorphism pop */
        body::before, body::after {
            content: '';
            position: absolute;
            border-radius: 50%;
            filter: blur(80px);
            z-index: -1;
            animation: float 10s ease-in-out infinite alternate;
        }

        body::before {
            width: 300px;
            height: 300px;
            background: rgba(138, 79, 255, 0.15);
            top: 20%;
            left: 25%;
        }

        body::after {
            width: 400px;
            height: 400px;
            background: rgba(196, 158, 255, 0.1);
            bottom: 10%;
            right: 20%;
            animation-delay: -5s;
        }

        @keyframes float {
            0% { transform: translateY(0px) translateX(0px); }
            100% { transform: translateY(-30px) translateX(20px); }
        }

        .login-card {
            background: var(--card-bg);
            padding: 45px 35px;
            border-radius: 24px;
            box-shadow: 0 15px 35px rgba(0, 0, 0, 0.5), inset 0 1px 0 rgba(255, 255, 255, 0.1);
            backdrop-filter: blur(20px) saturate(150%);
            -webkit-backdrop-filter: blur(20px) saturate(150%);
            border: 1px solid var(--card-border);
            width: 100%;
            max-width: 400px;
            text-align: center;
            transition: all 0.4s cubic-bezier(0.25, 0.8, 0.25, 1);
            animation: cardEntrance 0.8s ease-out forwards;
        }

        @keyframes cardEntrance {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }

        h1 {
            font-family: 'Georgia', serif;
            color: var(--text-main);
            margin-bottom: 5px;
            font-size: 2.2rem;
            letter-spacing: 1.5px;
            text-shadow: 0 0 15px rgba(196, 158, 255, 0.3);
        }

        p.subtitle {
            font-size: 0.9rem;
            color: #a097b5;
            margin-bottom: 35px;
            font-style: italic;
            letter-spacing: 0.5px;
        }

        .input-group {
            margin-bottom: 22px;
            text-align: left;
        }

        .input-group label {
            display: block;
            font-size: 0.85rem;
            margin-bottom: 8px;
            color: var(--text-accent);
            font-weight: 500;
            letter-spacing: 0.5px;
        }

        .input-group input {
            width: 100%;
            padding: 14px;
            background: var(--input-bg);
            border: 1px solid var(--input-border);
            border-radius: 12px;
            box-sizing: border-box;
            font-size: 1rem;
            color: #ffffff;
            transition: all 0.3s ease;
        }

        .input-group input::placeholder {
            color: rgba(232, 227, 245, 0.3);
        }

        .input-group input:focus {
            outline: none;
            border-color: var(--input-focus);
            background: rgba(255, 255, 255, 0.08);
            box-shadow: 0 0 15px rgba(212, 179, 255, 0.25);
            transform: translateY(-2px);
        }

        button[type="submit"] {
            width: 100%;
            padding: 15px;
            background: var(--btn-bg);
            color: white;
            border: none;
            border-radius: 12px;
            font-size: 1.05rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1px;
            cursor: pointer;
            transition: all 0.3s ease;
            margin-top: 10px;
            box-shadow: 0 4px 15px rgba(138, 79, 255, 0.2);
        }

        button[type="submit"]:hover {
            box-shadow: 0 8px 25px var(--btn-hover-shadow);
            transform: translateY(-2px);
            filter: brightness(1.1);
        }
        
        button[type="submit"]:active {
            transform: scale(0.98);
            box-shadow: 0 2px 10px rgba(138, 79, 255, 0.2);
        }

        .toggle-link {
            margin-top: 25px;
            font-size: 0.85rem;
            color: #a097b5;
            cursor: pointer;
            text-decoration: none;
            display: inline-block;
            transition: color 0.3s ease;
            border-bottom: 1px dashed transparent;
        }

        .toggle-link:hover {
            color: var(--text-accent);
            border-bottom: 1px dashed var(--text-accent);
        }

        /* Hide elements smoothly */
        .hidden {
            display: none;
        }
        
        /* Error message styling */
        #error-msg {
            color: #ff6b6b;
            font-size: 0.9rem;
            margin-bottom: 15px;
            min-height: 20px;
            font-weight: 500;
            text-shadow: 0 0 10px rgba(255, 107, 107, 0.3);
        }
    </style>
</head>
<body>

    <div class="login-card">
        <h1>Kartik & Vaibhav</h1>
        <p class="subtitle">Our little corner of the internet.</p>
        
        <div id="error-msg"></div>

        <!-- Standard Password Form -->
        <form id="password-form" onsubmit="handleLogin(event, 'password')">
            <div class="input-group">
                <label for="password">Our Secret Password</label>
                <input type="password" id="password" name="password" required placeholder="Enter password...">
            </div>
            <button type="submit">Unlock</button>
        </form>

        <!-- Alternative Q&A Form -->
        <form id="questions-form" class="hidden" onsubmit="handleLogin(event, 'questions')">
            <div class="input-group">
                <label for="q1">1. Name of Vaibhu's boobies?</label>
                <input type="text" id="q1" name="q1" required placeholder="Your answer...">
            </div>
            <div class="input-group">
                <label for="q2">2. Our anniversary date is? (format: DD/MM/YYYY)</label>
                <input type="text" id="q2" name="q2" required placeholder="Your answer...">
            </div>
            <div class="input-group">
                <label for="q3">3. Our fav emojis are? (in correct order, without space)</label>
                <input type="text" id="q3" name="q3" required placeholder="Your answer...">
            </div>
            <button type="submit">Unlock</button>
        </form>

        <div class="toggle-link" onclick="toggleForms()">Or answer our personal questions</div>
    </div>

    <script>
        // Toggles between the password and the 3 questions
        function toggleForms() {
            const pwdForm = document.getElementById('password-form');
            const qForm = document.getElementById('questions-form');
            const toggleLink = document.querySelector('.toggle-link');
            const errorMsg = document.getElementById('error-msg');
            
            errorMsg.innerText = ''; // Clear errors on toggle

            if (pwdForm.classList.contains('hidden')) {
                pwdForm.classList.remove('hidden');
                qForm.classList.add('hidden');
                toggleLink.innerText = 'Or answer our personal questions';
            } else {
                pwdForm.classList.add('hidden');
                qForm.classList.remove('hidden');
                toggleLink.innerText = 'Use our secret password instead';
            }
        }

        // Submits the data to our Vercel Serverless Function (which we will build next)
        async function handleLogin(e, type) {
            e.preventDefault();
            const errorMsg = document.getElementById('error-msg');
            const btn = e.target.querySelector('button');
            errorMsg.innerText = '';
            
            // Temporary loading state
            const originalBtnText = btn.innerText;
            btn.innerText = 'CHECKING...';

            const formData = new FormData(e.target);
            const data = Object.fromEntries(formData.entries());
            data.loginType = type; // Tells the backend which method we used

            try {
                const response = await fetch('/api/login', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data)
                });

                if (response.ok) {
                    window.location.href = '/'; // Success! Redirect to the garden
                } else {
                    const resData = await response.json();
                    errorMsg.innerText = resData.message || 'Incorrect. Try again, love. ❤️';
                    btn.innerText = originalBtnText;
                }
            } catch (err) {
                errorMsg.innerText = 'Network error. Please try again.';
                btn.innerText = originalBtnText;
            }
        }
    </script>
</body>
</html>